<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:orientation="horizontal">

    <LinearLayout
         android:layout_height="match_parent"
         android:layout_width="300dp"
         android:visibility="gone"
         android:background="#333333"
         android:id="@+id/liner">

        <TextView
             android:layout_height="40dp"
             android:layout_width="40dp"
             android:gravity="center"
             android:background="#ff0000"
             android:textColor="#afffff"
             android:id="@+id/keluar"
             android:text="X" />

    </LinearLayout>

    <LinearLayout
         android:layout_height="match_parent"
         android:layout_width="match_parent"
         android:orientation="vertical">

        <LinearLayout
             android:layout_height="40dp"
             android:layout_width="match_parent"
             android:layout_marginBottom="10dp"
             android:gravity="center_vertical"
             android:background="#555555"
             android:orientation="horizontal">

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:src="@drawable/nav"
                 android:layout_marginEnd="30dp"
                 android:id="@+id/nav" />

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:src="@drawable/memo_apk"
                 android:layout_marginEnd="10dp"
                 android:id="@+id/apk" />

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:src="@drawable/sd_card"
                 android:layout_marginEnd="10dp"
                 android:id="@+id/sdCard" />

            <TextView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:layout_marginEnd="10dp"
                 android:gravity="center"
                 android:background="#afffff"
                 android:textSize="20dp"
                 android:textColor="#000000"
                 android:text="+"
                 android:id="@+id/baru" />

            <ImageView
                 android:layout_height="30dp"
                 android:layout_width="30dp"
                 android:visibility="gone"
                 android:src="@drawable/kembali"
                 android:layout_marginStart="20dp"
                 android:id="@+id/kembali" />

        </LinearLayout>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:background="#343434"
             android:layout_margin="5dp"
             android:textSize="12dp"
             android:textColor="#afffff"
             android:id="@+id/jalur"
             android:text="/" />

        <LinearLayout
             android:layout_height="35dp"
             android:layout_width="match_parent"
             android:visibility="gone"
             android:gravity="center"
             android:background="#0f4d4d"
             android:id="@+id/lama">

            <ImageView
                 android:layout_height="25dp"
                 android:layout_width="25dp"
                 android:src="@drawable/salin"
                 android:layout_marginEnd="15dp"
                 android:id="@+id/salin" />

            <ImageView
                 android:layout_height="25dp"
                 android:layout_width="25dp"
                 android:src="@drawable/potong"
                 android:layout_marginEnd="15dp"
                 android:id="@+id/potong" />

            <ImageView
                 android:layout_height="25dp"
                 android:layout_width="25dp"
                 android:src="@drawable/rename"
                 android:layout_marginEnd="15dp"
                 android:id="@+id/rename" />

            <ImageView
                 android:layout_height="25dp"
                 android:layout_width="25dp"
                 android:src="@drawable/hapus"
                 android:layout_marginEnd="15dp"
                 android:id="@+id/hapus" />

            <ImageView
                 android:layout_height="25dp"
                 android:layout_width="25dp"
                 android:src="@drawable/lainya"
                 android:layout_marginEnd="15dp"
                 android:id="@+id/lainya" />

            <ImageView
                 android:layout_height="25dp"
                 android:layout_width="25dp"
                 android:visibility="gone"
                 android:src="@drawable/tempel"
                 android:layout_marginEnd="15dp"
                 android:id="@+id/tempel" />

        </LinearLayout>

        <LinearLayout
             android:layout_height="match_parent"
             android:layout_width="match_parent"
             android:layout_margin="10dp">

            <ScrollView
                 android:layout_height="match_parent"
                 android:layout_width="match_parent">

                <GridLayout
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:id="@+id/grid"
                     android:layout_gravity="center_horizontal"
                     android:columnCount="3">

                </GridLayout>

            </ScrollView>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>